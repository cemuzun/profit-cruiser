# Every 12h: 08:00 and 20:00 UTC — full scrape of all cities
0 8,20 * * * root cd /app && /usr/bin/node scraper.mjs >> /var/log/cron.log 2>&1
# Every minute: drain any 'pending' scrape_runs queued by the dashboard button
* * * * * root cd /app && /usr/bin/node queue-worker.mjs >> /var/log/cron.log 2>&1
